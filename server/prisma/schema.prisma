generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  macroGoal MacroGoal?
  foodLogs  FoodLog[]
  waterLogs WaterLog[]
  savedMeal SavedMeal[]
}

model MacroGoal {
  id       String @id @default(uuid())
  userId   String @unique
  calories Int
  protein  Int
  carbs    Int
  fat      Int

  user User @relation(fields: [userId], references: [id])
}

model FoodLog {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime @db.Date
  meal        String   @default("snack")
  foodName    String
  servingSize Float    @default(100)
  servingUnit String   @default("g")
  calories    Int
  protein     Float
  carbs       Float
  fat         Float
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model WaterLog {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @db.Date
  amount    Float
  unit      String   @default("oz")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SavedMeal {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id])
  items SavedMealItem[]
}

model SavedMealItem {
  id          String  @id @default(uuid())
  savedMealId String
  foodName    String
  servingSize Float
  servingUnit String  @default("g")
  calories    Int
  protein     Float
  carbs       Float
  fat         Float

  savedMeal SavedMeal @relation(fields: [savedMealId], references: [id], onDelete: Cascade)
}